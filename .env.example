# ============================================================
# First City Foundry — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env to git — it's in .gitignore
# ============================================================

# ── Email (Brevo SMTP) ──────────────────────────────────────
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_SMTP_LOGIN=your-brevo-login@smtp-brevo.com
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
FROM_EMAIL=hello@firstcityfoundry.com
FROM_NAME=First City Foundry
REPLY_TO_EMAIL=hello@firstcityfoundry.com
DAILY_NOTIFICATION_EMAIL=you@example.com
DAILY_CC_EMAIL=

# ── OpenAI (AI content generation) ──────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Social Media ─────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# ── Google Analytics ─────────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CREDENTIALS_FILE=
GOOGLE_ANALYTICS_API_KEY=

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=

# ── Search APIs (optional) ───────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
BING_API_KEY=

# ── Rate Limits ──────────────────────────────────────────────
MAX_DAILY_OUTREACH=50
MAX_PER_ORGANIZATION=4
MIN_DELAY_SECONDS=30
MAX_DELAY_SECONDS=60

# ── Site ─────────────────────────────────────────────────────
WEBSITE_URL=https://www.firstcityfoundry.com
SITE_NAME=First City Foundry

# ── Notifications ────────────────────────────────────────────
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
